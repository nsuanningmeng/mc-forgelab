{
  "name": "@mc-forgelab/web",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mc-forgelab/app-error": "workspace:*",
    "@mc-forgelab/storage": "workspace:*",
    "@mc-forgelab/config": "workspace:*",
    "@mc-forgelab/ai-provider-manager": "workspace:*",
    "@mc-forgelab/ai-workflow-engine": "workspace:*",
    "@mc-forgelab/artifact-manager": "workspace:*",
    "@mc-forgelab/build-orchestrator": "workspace:*",
    "@mc-forgelab/toolchain-manager": "workspace:*",
    "@mc-forgelab/template-engine": "workspace:*",
    "@mc-forgelab/project-model": "workspace:*",
    "@mc-forgelab/knowledge-base": "workspace:*",
    "@mc-forgelab/target-registry": "workspace:*",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
