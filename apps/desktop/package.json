{
  "name": "@mc-forgelab/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -b && electron .",
    "build": "tsc -b",
    "dist": "tsc -b && electron-builder",
    "typecheck": "tsc -b",
    "test": "echo \"no tests\" && exit 0",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mc-forgelab/web": "workspace:*",
    "@mc-forgelab/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.mc-forgelab.desktop",
    "productName": "MC ForgeLab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/@mc-forgelab/web/dist/**/*",
      "node_modules/@mc-forgelab/web/public/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "MC ForgeLab",
      "deleteAppDataOnUninstall": false,
      "installerLanguages": ["en_US", "zh_CN"],
      "language": "2052"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png"
    },
    "publish": null
  }
}
