{
  "name": "@mc-forgelab/desktop",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -b && electron .",
    "build": "tsc -b",
    "dist": "tsc -b && electron-builder",
    "typecheck": "tsc -b",
    "test": "echo \"no tests\" && exit 0",
    "clean": "rimraf dist *.tsbuildinfo",
    "rebuild:native": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mc-forgelab/web": "workspace:*",
    "@mc-forgelab/config": "workspace:*",
    "@mc-forgelab/storage": "workspace:*",
    "@mc-forgelab/app-error": "workspace:*",
    "@mc-forgelab/logger": "workspace:*",
    "@mc-forgelab/ai-provider-manager": "workspace:*",
    "@mc-forgelab/ai-workflow-engine": "workspace:*",
    "@mc-forgelab/artifact-manager": "workspace:*",
    "@mc-forgelab/build-orchestrator": "workspace:*",
    "@mc-forgelab/toolchain-manager": "workspace:*",
    "@mc-forgelab/template-engine": "workspace:*",
    "@mc-forgelab/project-model": "workspace:*",
    "@mc-forgelab/file-operation": "workspace:*",
    "@mc-forgelab/compatibility": "workspace:*",
    "@mc-forgelab/target-registry": "workspace:*",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@types/node": "^22.10.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.mc-forgelab.desktop",
    "productName": "MC ForgeLab",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/@mc-forgelab/*/dist/**/*",
      "node_modules/@mc-forgelab/*/package.json",
      "node_modules/@mc-forgelab/web/public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "MC ForgeLab",
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ],
      "displayLanguageSelector": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "publish": null
  }
}
