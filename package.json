{
  "name": "mc-forgelab",
  "version": "0.1.0",
  "private": true,
  "description": "Minecraft plugin / mod / hybrid project generator, builder and download platform — desktop GUI / CLI / WebUI in Docker.",
  "type": "module",
  "engines": {
    "node": ">=20.18"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "cli": "pnpm --filter @mc-forgelab/cli start --",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://example.invalid/mc-forgelab.git"
  }
}
