{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "description": "MC-ForgeLab Design Tokens — consumed by apps/web (Tailwind config) and apps/desktop (Electron renderer). Stage 3+ implementation.",
  "color": {
    "brand": {
      "primary": "#52A535",
      "primaryHover": "#418A2A",
      "primaryActive": "#356E22",
      "primaryContrast": "#FFFFFF"
    },
    "accent": {
      "diamond": "#55FFFF",
      "redstone": "#FF5050",
      "gold": "#FFAA00",
      "obsidian": "#2C2640"
    },
    "neutral": {
      "0": "#FFFFFF",
      "50": "#F7F7F7",
      "100": "#EDEDED",
      "200": "#D6D6D6",
      "300": "#B8B8B8",
      "400": "#8E8E8E",
      "500": "#666666",
      "600": "#4A4A4A",
      "700": "#3C3C3C",
      "800": "#2A2A2A",
      "900": "#1E1E1E",
      "950": "#121212"
    },
    "status": {
      "success": "#22C55E",
      "warning": "#EAB308",
      "error": "#EF4444",
      "info": "#3B82F6"
    },
    "surface": {
      "dark": {
        "background": "#121212",
        "foreground": "#EDEDED",
        "card": "#1E1E1E",
        "border": "#3C3C3C",
        "muted": "#8E8E8E"
      },
      "light": {
        "background": "#FAFAFA",
        "foreground": "#1E1E1E",
        "card": "#FFFFFF",
        "border": "#D6D6D6",
        "muted": "#666666"
      }
    }
  },
  "spacing": {
    "0": "0px",
    "0.5": "2px",
    "1": "4px",
    "1.5": "6px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "borderRadius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.08)",
    "md": "0 4px 8px rgba(0,0,0,0.12)",
    "lg": "0 12px 24px rgba(0,0,0,0.16)",
    "xl": "0 24px 48px rgba(0,0,0,0.20)",
    "focus": "0 0 0 3px rgba(82,165,53,0.35)"
  },
  "typography": {
    "fontFamily": {
      "sans": "'Inter', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      "mono": "'JetBrains Mono', 'Cascadia Code', 'Fira Code', Consolas, monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "13px",
      "base": "14px",
      "lg": "16px",
      "xl": "18px",
      "2xl": "22px",
      "3xl": "28px"
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "snug": 1.4,
      "normal": 1.5,
      "relaxed": 1.7
    }
  },
  "motion": {
    "duration": {
      "instant": "100ms",
      "fast": "150ms",
      "base": "200ms",
      "slow": "300ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "accelerate": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "z": {
    "base": 0,
    "dropdown": 100,
    "sticky": 200,
    "drawer": 300,
    "modal": 400,
    "toast": 500,
    "tooltip": 600
  }
}
